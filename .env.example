# ────────── Staging (Base Sepolia) ──────────
# Use these values for testnet deployment.
# RPC: ethereum Sepolia endpoint for Base Sepolia.
# USDC: official Base Sepolia USDC contract.
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
ESCROW_CONTRACT_ADDRESS=replace-after-deploy
INDEXER_START_BLOCK=replace-after-deploy

# ────────── Blockchain ──────────
# Override CHAIN_ID/RPC_URL/USDC/ESCROW for local Anvil testing.
# CHAIN_ID=31337
# RPC_URL=http://127.0.0.1:8545

# ────────── Escrow governance ──────────
# Set these BEFORE deploying. They are read by DeploySepolia.s.sol.
ESCROW_ADMIN=0x0000000000000000000000000000000000000000
ESCROW_ARBITRATOR=0x0000000000000000000000000000000000000000
FEE_RECIPIENT=0x0000000000000000000000000000000000000000
PLATFORM_FEE_BPS=500
MAX_JOB_AMOUNT=10000000000

# PRIVATE_KEY is read by forge script --sender.
# WARNING: never commit this file if PRIVATE_KEY is set here.
# PRIVATE_KEY=0x...

# ────────── Backend ──────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/freelance_escrow
REDIS_URL=redis://localhost:6379/0
API_CORS_ORIGINS=http://localhost:5173

# ────────── Frontend ──────────
VITE_API_BASE_URL=http://localhost:8000
VITE_CHAIN_ID=${CHAIN_ID}
VITE_ESCROW_CONTRACT_ADDRESS=${ESCROW_CONTRACT_ADDRESS}
VITE_USDC_CONTRACT_ADDRESS=${USDC_CONTRACT_ADDRESS}
VITE_WALLETCONNECT_PROJECT_ID=replace-me
